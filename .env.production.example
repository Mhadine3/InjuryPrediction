# =============================================================
# Production environment for the VPS deploy.
# Copy this to ".env" on the server and fill in real values:
#   cp .env.production.example .env
# NEVER commit the real .env (it is gitignored).
# =============================================================

# --- Domain (used by Caddy for automatic HTTPS) ---
# e.g. yourname.duckdns.org  — must point at this VPS's IP.
DOMAIN=changeme.duckdns.org

# --- Database (Postgres/TimescaleDB container) ---
POSTGRES_USER=injury
POSTGRES_PASSWORD=CHANGE_ME_to_a_long_random_password
POSTGRES_DB=injury_prediction

# --- App: must match the Postgres values above, host is the compose service "db" ---
DATABASE_URL=postgresql+asyncpg://injury:CHANGE_ME_to_a_long_random_password@db:5432/injury_prediction

ENVIRONMENT=production

# Comma-separated allowed browser origins. Same-origin (Caddy) needs none,
# but list the public URL so external callers / tools work.
CORS_ORIGINS=https://changeme.duckdns.org

# --- External API keys ---
# Rotate the football-data key before deploying (the old one was committed).
FOOTBALL_DATA_API_KEY=your_new_football_data_key
BSD_TOKEN=your_bsd_token
